#!/usr/bin/env bash
# Run cardql from repo source without reinstalling. Usage: ./run init | ./run fetch | ./run parse | etc.
# Prefers .venv or venv in repo if present (install deps with `pip install -r requirements.txt`).
set -e
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
export PYTHONPATH="${REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
if [ -x "${REPO_ROOT}/.venv/bin/python" ]; then
  exec "${REPO_ROOT}/.venv/bin/python" -m cardql "$@"
elif [ -x "${REPO_ROOT}/venv/bin/python" ]; then
  exec "${REPO_ROOT}/venv/bin/python" -m cardql "$@"
else
  exec python3 -m cardql "$@"
fi
